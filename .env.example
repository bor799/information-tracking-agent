# V3 placeholders only. Do not copy V2 secrets into this file.
STATE_ROOT=~/.100x_v3
QUEUE_DB_PATH=~/.100x_v3/queue.db
LOG_PATH=~/100x-v3-daemon.log
CONFIG_PATH=config/config.local.yaml

# Add real credentials only in an untracked local file when live integrations exist.
ZHIPU_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# Search capabilities (Exa API)
# Get API key from https://exa.ai
EXA_API_KEY=

# Alternatively, use mcporter with Exa MCP server (no API key needed)
# Install: https://github.com/yourusername/mcporter
# Run: mcporter config add exa https://mcp.exa.ai/mcp

# ========================================
# Agent-Reach 多平台抓取配置 (从 V2 迁移)
# ========================================

# YouTube (yt-dlp) 代理配置（可选）
# 留空使用 TUN 或自动探测常用端口
HTTP_PROXY=
HTTPS_PROXY=

# Twitter/X (xreach) 认证配置
# 从浏览器提取认证信息:
#   xreach auth extract --browser chrome
# 或手动设置 (从浏览器的 localStorage 复制):
TWITTER_AUTH_TOKEN=
TWITTER_CT0=

# xreach CLI 路径（如果不在 PATH 中）
XREACH_PATH=/Users/murphy/.npm-global/bin/xreach

# yt-dlp 路径（如果不在 PATH 中）
YT_DLP_PATH=/opt/miniconda3/bin/yt-dlp
